#!/bin/sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
CHECKER_SCRIPT="$REPO_ROOT/scripts/checklist-gate.ps1"

if [ ! -f "$CHECKER_SCRIPT" ]; then
  echo "Checklist gate script not found: $CHECKER_SCRIPT" >&2
  exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$CHECKER_SCRIPT"
elif command -v powershell >/dev/null 2>&1; then
  powershell -NoProfile -ExecutionPolicy Bypass -File "$CHECKER_SCRIPT"
else
  echo "PowerShell not found. Install PowerShell 7 (pwsh) or Windows PowerShell." >&2
  exit 1
fi